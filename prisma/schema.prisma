generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model catch_histories {
  id              Int          @id @default(autoincrement())
  community_id    Int?
  month_year      String       @db.VarChar(7)
  total_weight_kg Int
  revenue_idr     BigInt
  communities     communities? @relation(fields: [community_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model communities {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(100)
  location        String            @db.VarChar(100)
  risk_score      String?           @db.VarChar(10)
  created_at      DateTime?         @default(now()) @db.Timestamp(6)
  catch_histories catch_histories[]
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   // 'INVESTOR' atau 'NELAYAN'
  createdAt DateTime @default(now())
}